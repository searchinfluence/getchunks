{
  "name": "@search-influence/web-content-chunker",
  "version": "3.0.0",
  "description": "Intelligent web content extraction for RAG. Defuddle-powered main-content extraction, accurate BPE token counting, heading breadcrumbs, source metadata (JSON-LD, OpenGraph, Twitter), and multiple output formats (JSON, Markdown, JSONL, LangChain). Zero AI/LLM dependencies.",
  "type": "module",
  "main": "api/chunk.js",
  "scripts": {
    "build": "node scripts/build.js",
    "serve": "python3 -m http.server 8080",
    "demo": "open public/index.html"
  },
  "keywords": [
    "chunking",
    "rag",
    "llm",
    "content-extraction",
    "web-scraping",
    "nlp",
    "text-processing",
    "search-influence"
  ],
  "author": "Search Influence",
  "license": "MIT",
  "homepage": "https://getchunks.searchinfluence.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/willscott-v2/getchunks"
  },
  "bugs": {
    "url": "https://github.com/willscott-v2/getchunks/issues"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "defuddle": "^0.16.0",
    "gpt-tokenizer": "^3.4.0",
    "linkedom": "^0.18.12",
    "node-fetch": "^3.3.2",
    "sbd": "^1.0.19"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
